{
  "name": "imezzi",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Live transit map of Genoa — AMT vehicles, stops, red/black civic numbers and multimodal routing. Astro + Lit + MapLibre on Cloudflare Workers.",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "test": "bun test test",
    "test:e2e": "playwright test --reporter=list",
    "data": "bun scripts/build-gtfs.ts",
    "lint": "eslint src test worker scripts",
    "typecheck": "astro check && tsc --noEmit -p tsconfig.test.json",
    "check": "bun run lint && bun run typecheck && bun run test",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "astro": "^5.17.1",
    "effect": "^3.19.4",
    "lit": "^3.3.2",
    "maplibre-gl": "^5.6.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@playwright/test": "^1.61.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.0.0",
    "eslint": "^9.39.1",
    "fflate": "^0.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "wrangler": "^4.80.0"
  }
}
